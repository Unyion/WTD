{
  "name": "wtd-app",
  "version": "1.2.1",
  "description": "What To Do - Activity suggestion app based on weather and preferences",
  "main": "main.js",
  "homepage": "https://github.com/Unyion/WTD",
  "repository": {
    "type": "git",
    "url": "https://github.com/Unyion/WTD.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "dist": "node scripts/run-dist.js"
  },
  "dependencies": {
    "electron-updater": "^6.6.2"
  },
  "keywords": [
    "activity",
    "weather",
    "recommendation",
    "desktop"
  ],
  "author": {
    "name": "Jackson Bigelow",
    "email": "273222488+Unyion@users.noreply.github.com"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.jacksonbigelow.wtd",
    "productName": "What To Do",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "main.js",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.lifestyle",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "guid": "b30f52a0-820a-5593-ba8f-5b6dc907e284",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "What To Do",
      "menuCategory": "What To Do",
      "runAfterFinish": true,
      "include": "build/installer.nsh"
    },
    "linux": {
      "category": "Utility",
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "Unyion",
      "repo": "WTD"
    }
  }
}
